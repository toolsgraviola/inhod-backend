NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=mysql://surfabroad:surfabroad@localhost:3306/surfabroad
SHADOW_DATABASE_URL=mysql://root:root@localhost:3306/surfabroad_shadow

# Local-only convenience. Do not enable in staging or production.
ALLOW_DEV_AUTH=false

# Super Admin authentication.
ADMIN_TOKEN_SECRET=change-this-local-admin-secret
ADMIN_TOKEN_EXPIRES_IN_MINUTES=720
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=Admin@12345
ADMIN_SEED_NAME=INHOD Admin

# Firebase Admin SDK. Use either GOOGLE_APPLICATION_CREDENTIALS or explicit service account values.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Payment gateway placeholders.
PAYMENT_GATEWAY=stripe
PAYMENT_WEBHOOK_SECRET=

# Storage placeholders.
STORAGE_PROVIDER=s3
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
